# Copy file này thành .env. KHÔNG commit file .env lên GitHub.
# Toàn bộ stack mặc định là FREE — không cần Anthropic/OpenAI key.

# --- Generation backend ---
# "ollama" (mặc định, dùng khi dev local, 100% free, không giới hạn)
# "groq"   (dùng khi deploy demo public lên HF Spaces, free tier)
GENERATION_BACKEND=ollama

# Model local qua Ollama (cài Ollama trước: https://ollama.com, sau đó `ollama pull qwen2.5:3b-instruct`)
OLLAMA_MODEL=qwen2.5:3b-instruct

# Groq free tier — lấy key miễn phí tại https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Vector store (local, free) ---
CHROMA_PERSIST_DIR=./data/processed/chroma_db

# --- Embedding models (local, free, tự tải từ Hugging Face) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
